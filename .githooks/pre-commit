#!/bin/sh
# Block build artifacts, binaries, secrets, and local-only files from being committed.

set -e

blocked=0

check_name() {
  file="$1"
  case "$file" in
    frontend/dist/*|frontend/dist)
      echo "BLOCKED: $file (build output — run npm run build locally, do not commit dist/)"
      blocked=1
      ;;
    build/bin/*|build/bin)
      echo "BLOCKED: $file (Wails build output)"
      blocked=1
      ;;
    node_modules/*|node_modules)
      echo "BLOCKED: $file (dependencies — run npm install locally)"
      blocked=1
      ;;
    .env|.env.*)
      case "$file" in
        .env.example) ;;
        *)
          echo "BLOCKED: $file (environment / secrets file)"
          blocked=1
          ;;
      esac
      ;;
    *.exe|*.exe.bak|*.msix)
      echo "BLOCKED: $file (binary installer)"
      blocked=1
      ;;
    *.pfx|*.p12|*.pem|*.key)
      echo "BLOCKED: $file (certificate or private key)"
      blocked=1
      ;;
    frontend/package.json.md5)
      echo "BLOCKED: $file (Wails dev artifact)"
      blocked=1
      ;;
    settings.json)
      echo "BLOCKED: $file (local user settings)"
      blocked=1
      ;;
  esac
}

staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$staged_files" ]; then
  exit 0
fi

for file in $staged_files; do
  check_name "$file"
done

if [ "$blocked" -ne 0 ]; then
  echo ""
  echo "Commit rejected. Remove blocked paths from the index, e.g.:"
  echo "  git reset HEAD -- <path>"
  echo "See .gitignore and README.md."
  exit 1
fi

exit 0
